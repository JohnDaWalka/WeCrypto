{
  "name": "we-cfm-orchestrator",
  "version": "2.4.1",
  "private": true,
  "description": "WalkerEnterprise CFM benchmark orchestration engine",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.walkerenterprise.wecfmorchestrator",
    "productName": "WE--CRYPTO--BETA2",
    "electronVersion": "37.2.0",
    "artifactName": "WECRYPTO-v${version}-portable.exe",
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "predictions.js",
      "cfm-engine.js",
      "prediction-markets.js",
      "market-resolver.js",
      "data.js",
      "main.js",
      "preload.js",
      "app-icon.ico",
      "app-icon.png",
      "pwa-icon.svg",
      "manifest.webmanifest",
      "sw.js",
      "proxy-fetch.js",
      "throttled-fetch.js",
      "social-sentiment.js",
      "candle-ws.js",
      "orderbook.js",
      "signal-router-cfm.js",
      "shell-router.js",
      "floating-orchestrator.js",
      "chain-router.js",
      "wallet-cache.js",
      "cex-flow.js",
      "blockchain-scan.js",
      "data-logger.js",
      "tauri-bridge.js",
      "chart.umd.min.js",
      "chartjs-adapter-date-fns.bundle.min.js",
      "lightweight-charts.standalone.production.js",
      "we-crypto-proxy.exe",
      "package.json"
    ],
    "asarUnpack": [
      "we-crypto-proxy.exe"
    ],
    "icon": "app-icon.ico",
    "win": {
      "icon": "app-icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^25.1.8"
  }
}