{
  "name": "we-cfm-orchestrator",
  "version": "2.5.0-momentum",
  "private": true,
  "description": "WalkerEnterprise CFM benchmark orchestration engine",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "build": {
    "appId": "com.walkerenterprise.wecfmorchestrator",
    "productName": "WE--CRYPTO--BETA2",
    "electronVersion": "37.2.0",
    "artifactName": "WECRYPTO-v${version}-portable.exe",
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "main.js",
      "preload.js",
      "sw.js",
      "manifest.webmanifest",
      "app-icon.ico",
      "app-icon.png",
      "pwa-icon.svg",
      "package.json",
      "src/**/*",
      "vendor/**/*",
      "we-crypto-proxy.exe"
    ],
    "asarUnpack": [
      "we-crypto-proxy.exe"
    ],
    "icon": "app-icon.ico",
    "win": {
      "icon": "app-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WE--CRYPTO--BETA2"
    }
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "electron": "^37.2.0",
    "electron-builder": "^25.1.8"
  }
}
