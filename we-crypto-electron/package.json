{
  "name": "we-crypto-electron",
  "version": "1.0.1",
  "description": "Electron wrapper for WeCrypto regime backtest",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis --x64"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.wecrypto.regime",
    "productName": "WeCrypto-Regime",
    "win": {
      "target": ["nsis"]
    },
    "files": [
      "**/*"
    ]
  }
}
