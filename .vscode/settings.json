{
    "emmet.triggerExpansionOnTab": true,
    "intelephense.codeLens.usages.enable": true,
    "typescript.tsdk": "node_modules/typescript/lib",
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    },
    "files.associations": {
        "*.rules": "firestore-security-rules"
    },
    "geminicodeassist.agentDebugMode": true,
    "geminicodeassist.agentYoloMode": true,
    "geminicodeassist.chat.changeView": "Default diff view",
    "geminicodeassist.codeGenerationPaneViewEnabled": true,
    "geminicodeassist.contextExclusionFile": "",
    "geminicodeassist.inlineSuggestions.nextEditPredictions": true,
    "geminicodeassist.verboseLogging": true,
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "notebook.defaultFormatter": "vscode.typescript-language-features",
    "github.copilot.chat.alternateGeminiModelFPrompt.enabled": true,
    "github.copilot.chat.copilotMemory.enabled": true,
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "markdown.validate.enabled": true,
    "files.autoSave": "afterDelay",
    "editor.codeActions.triggerOnFocusChange": true
}