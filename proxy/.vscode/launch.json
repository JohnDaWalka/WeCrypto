{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug we-crypto-proxy",
      "cargo": {
        "args": ["build", "--bin=we-crypto-proxy", "--package=we-crypto-proxy"],
        "filter": {
          "name": "we-crypto-proxy",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_LOG": "we_crypto_proxy=debug"
      }
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Run proxy (release)",
      "cargo": {
        "args": ["build", "--release", "--bin=we-crypto-proxy"],
        "filter": {
          "name": "we-crypto-proxy",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_LOG": "we_crypto_proxy=info"
      }
    }
  ]
}
